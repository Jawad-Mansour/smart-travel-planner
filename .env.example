# BACKEND CONFIGURATION
APP_NAME="Smart Travel Planner"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-32-characters-secret-key
JWT_SECRET_KEY=change-this-to-32-characters-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# DATABASE
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travel_planner

# OPENAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_CHEAP_MODEL=gpt-4o-mini
OPENAI_STRONG_MODEL=gpt-4o

# WEATHER API
WEATHER_API_KEY=your-openweathermap-api-key

# FRONTEND
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
