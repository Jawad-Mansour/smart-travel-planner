# --- Core ---
APP_NAME="Smart Travel Planner"
APP_ENV=development
DEBUG=true

# --- Security (replace in production) ---
SECRET_KEY=change-this-to-32-characters-secret-key
JWT_SECRET_KEY=change-this-to-32-characters-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# Outbound webhooks (optional — Discord embed + Slack text)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Email when a plan is ready (optional — sends to the signed-in user's address)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Pause (seconds) between streamed destination segments in chat (lower locally, e.g. 0.35)
CHAT_SEGMENT_PAUSE_SEC=5

# --- Database (async SQLAlchemy + asyncpg) ---
# Local API + Postgres in Docker: use host port (compose maps 5432 and 55432 -> container 5432).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:55432/travel_planner
# Full Docker stack: compose overrides DATABASE_URL to @db:5432 — this line is for host-only Uvicorn.

# --- LLM ---
OPENAI_API_KEY=
OPENAI_CHEAP_MODEL=gpt-4o-mini
OPENAI_STRONG_MODEL=gpt-4o
ANTHROPIC_API_KEY=

# --- LangSmith (optional — tracing) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=smart-travel-planner

# --- Weather (OpenWeatherMap) ---
WEATHER_API_KEY=
WEATHER_CACHE_TTL_SECONDS=600

# --- Flights (Amadeus test API — optional; mock estimates if unset) ---
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
FLIGHTS_CACHE_TTL_SECONDS=3600

# --- FX (ExchangeRate-API — optional; open.er-api.com used if key unset) ---
EXCHANGE_RATE_API_KEY=
FX_BASE_URL=https://open.er-api.com/v6/latest
FX_CACHE_TTL_SECONDS=3600

# --- ML artifacts (paths relative to repo root in Docker: /app) ---
ML_MODELS_DIR=
ML_DESTINATIONS_CSV=

# --- Agent defaults ---
DEFAULT_FLIGHT_ORIGIN=NYC

# --- CORS (comma-separated; include every origin you open the UI from) ---
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1,http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000
